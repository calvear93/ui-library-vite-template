{
	"[html][json][jsonc][markdown][css][less]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[javascript][typescript][javascriptreact][typescriptreact]": {
		"editor.defaultFormatter": "dbaeumer.vscode-eslint"
	},
	"codeTemplateTool.templatesPath": "{workspace}/.vscode/__templates__",
	"css.lint.unknownAtRules": "ignore",
	"editor.detectIndentation": true,
	"editor.linkedEditing": true,
	"eslint.format.enable": true,
	"eslint.lintTask.enable": true,
	"eslint.probe": [
		"javascript",
		"javascriptreact",
		"typescript",
		"typescriptreact"
	],
	"eslint.trace.server": "off",
	"eslint.useESLintClass": true,
	"eslint.validate": [
		"javascript",
		"javascriptreact",
		"typescript",
		"typescriptreact"
	],
	"explorer.fileNesting.enabled": true,
	"explorer.fileNesting.expand": false,
	"explorer.fileNesting.patterns": {
		"*.cts": "${capture}.cts.*",
		"*.json": "${capture}.json, ${capture}.*.json",
		"*.mdx": "${capture}.*",
		"*.mts": "${capture}.mts.*",
		"*.ts": "${capture}.*",
		"*.tsx": "${capture}.*",
		".gitignore": ".gitattributes",
		"agents.md": "claude.md, gemini.md, llms.txt, .copilotignore",
		"eslint.config.js": ".prettierrc*, .prettierignore, .stylelintrc*, .stylelintignore, .editorconfig",
		"main.ts": "*.config.ts, *.d.ts",
		"package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, pnpm-workspace.yaml, package.*.json, .npmrc, .pnp.cjs",
		"readme*": "changelog.md, license.md, code_of_conduct.md, contributing.md, architecture.md",
		"tsconfig.json": "tsconfig.*.json",
		"vite.config.ts": "vitest.config.ts, unocss.config.ts, stryker.conf.*"
	},
	"explorer.incrementalNaming": "smart",
	"explorer.sortOrder": "type",
	"files.associations": {
		"*.md": "markdown",
		"tsconfig.*.json": "jsonc",
		"tsconfig.json": "jsonc"
	},
	"files.exclude": {
		"**/*.log": true,
		"**/*.tsbuildinfo": true,
		"**/.DS_Store": true,
		"**/.eslintcache": true,
		"**/.git": true,
		"**/.history": true,
		"**/.rollup.cache": true,
		"**/.stryker-tmp": true,
		"**/.stylelintcache": true,
		"**/.svn": true,
		"**/.swc": true,
		"**/.vite": true,
		"**/desktop.ini": true,
		"**/node_modules": true,
		"**/obj": true
	},
	"files.insertFinalNewline": true,
	"files.trimFinalNewlines": true,
	"files.trimTrailingWhitespace": true,
	"files.watcherExclude": {
		"**/.git/objects/**": true,
		"**/.rollup.cache": true,
		"**/.stryker-tmp": true,
		"**/.swc": true,
		"**/.vite": true,
		"**/build": true,
		"**/coverage": true,
		"**/dist": true,
		"**/node_modules/**": true
	},
	"html.autoClosingTags": true,
	"js/ts.autoClosingTags.enabled": true,
	"js/ts.preferences.importModuleSpecifier": "shortest",
	"js/ts.preferences.importModuleSpecifierEnding": "js",
	"js/ts.preferences.jsxAttributeCompletionStyle": "auto",
	"js/ts.preferences.preferTypeOnlyAutoImports": true,
	"js/ts.preferences.quoteStyle": "single",
	"js/ts.preferences.renameMatchingJsxTags": true,
	"js/ts.preferences.useAliasesForRenames": false,
	"js/ts.suggest.autoImports": true,
	"js/ts.tsdk.path": "node_modules\\typescript\\lib",
	"js/ts.tsserver.web.typeAcquisition.enabled": false,
	"js/ts.validate.enabled": true,
	"npm.packageManager": "pnpm",
	"npm.scriptRunner": "pnpm",
	"prettier.useTabs": true,
	"search.exclude": {
		"**/.rollup.cache": true,
		"**/.stryker-tmp": true,
		"**/.swc": true,
		"**/.vite": true,
		"**/.vscode": true,
		"**/build": true,
		"**/coverage": true,
		"**/dist": true,
		"**/package-lock.json": true,
		"**/pnpm-lock.yaml": true
	},
	"stylelint.packageManager": "pnpm",
	"stylelint.snippet": ["css"],
	"stylelint.validate": ["css"],
	"vitest.debugExclude": ["<node_internals>/**", "**/node_modules/**"],
	"vitest.filesWatcherInclude": "src/**/*.{spec,test}.?(m)[jt]s?(x)",
	"workbench.browser.openLocalhostLinks": true,
	"yaml.format.singleQuote": true
}
