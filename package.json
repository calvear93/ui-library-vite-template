{
	"$schema": "https://json.schemastore.org/package.json",
	"version": "0.0.1",
	"name": "(((lib-name)))",
	"description": "(((description)))",
	"repository": "(((repository)))",
	"license": "MIT",
	"keywords": [
		"react",
		"vite",
		"vitest",
		"typescript",
		"storybook",
		"ui",
		"component-library",
		"design-system",
		"unocss"
	],
	"scripts": {
		"dev": "storybook dev -p 5001",
		"build": "vite build",
		"build:storybook": "storybook build",
		"test": "vitest --coverage",
		"test:mutation": "stryker run",
		"lint": "eslint --cache --cache-location node_modules/.cache/eslint/",
		"stylelint": "stylelint --cache src/**/*.css --cache-location node_modules/.cache/stylelint/",
		"format": "prettier --cache --write **/*.{ts,mts,tsx,css,json,html,md,yml,yaml,webmanifest}",
		"clean": "pnpx del-cli dist .reports storybook-static **/*.tsbuildinfo"
	},
	"imports": {
		"#testing": "./src/__tests__/index.ts"
	},
	"sideEffects": [
		"**/*.css"
	],
	"peerDependencies": {
		"react": ">=18",
		"react-dom": ">=18"
	},
	"devDependencies": {
		"@faker-js/faker": "9.7.0",
		"@iconify-json/mdi": "1.2.3",
		"@storybook/addon-a11y": "10.4.4",
		"@storybook/addon-docs": "10.4.4",
		"@storybook/addon-links": "10.4.4",
		"@storybook/addon-onboarding": "10.4.4",
		"@storybook/react-vite": "10.4.4",
		"@stryker-mutator/core": "9.6.1",
		"@stryker-mutator/typescript-checker": "9.6.1",
		"@stryker-mutator/vitest-runner": "9.6.1",
		"@testing-library/dom": "10.4.1",
		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/react": "16.3.2",
		"@testing-library/user-event": "14.6.1",
		"@types/eslint": "9.6.1",
		"@types/node": "25.9.1",
		"@types/react": "19.2.16",
		"@types/react-dom": "19.2.3",
		"@unocss/eslint-config": "66.7.0",
		"@vitejs/plugin-react": "6.0.2",
		"@vitest/coverage-v8": "4.1.8",
		"@vitest/eslint-plugin": "1.6.19",
		"@whitespace/storybook-addon-html": "9.0.0",
		"eslint": "10.4.1",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-jest-dom": "5.5.0",
		"eslint-plugin-jsx-a11y": "6.10.2",
		"eslint-plugin-perfectionist": "5.9.0",
		"eslint-plugin-prettier": "5.5.6",
		"eslint-plugin-promise": "7.3.0",
		"eslint-plugin-react": "7.37.5",
		"eslint-plugin-regexp": "3.1.0",
		"eslint-plugin-sonarjs": "4.0.3",
		"eslint-plugin-storybook": "10.4.4",
		"eslint-plugin-testing-library": "7.16.2",
		"eslint-plugin-unicorn": "64.0.0",
		"glob": "11.0.2",
		"globals": "17.6.0",
		"happy-dom": "20.9.0",
		"postcss": "8.5.15",
		"prettier": "3.8.3",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"storybook": "10.4.4",
		"storybook-dark-mode": "5.0.0",
		"stylelint": "17.12.0",
		"stylelint-config-rational-order": "0.1.2",
		"stylelint-config-recommended": "18.0.0",
		"stylelint-config-standard": "40.0.0",
		"stylelint-order": "8.1.1",
		"stylelint-prettier": "5.0.3",
		"stylelint-use-nesting": "6.0.2",
		"tslib": "2.8.1",
		"typescript": "6.0.3",
		"typescript-eslint": "8.60.1",
		"unocss": "66.7.0",
		"vite": "8.0.16",
		"vite-plugin-checker": "0.14.1",
		"vite-plugin-dts": "5.0.2",
		"vite-plugin-lib-inject-css": "2.2.2",
		"vitest": "4.1.8",
		"vitest-mock-extended": "4.0.0"
	},
	"type": "module",
	"engines": {
		"node": ">=24",
		"npm": ">=11",
		"pnpm": ">=11"
	}
}
